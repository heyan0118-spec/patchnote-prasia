# App
APP_ENV=local
APP_PORT=3000
TZ=Asia/Seoul

# Nexon API
NEXON_API_BASE=https://public.api.nexon.com/community-ext-api/api/v1
NEXON_API_KEY=0a1a6fb8-8018-5a01-b9d9-91eabe96a0cc
NEXON_COMMUNITY_ID=299
NEXON_BOARD_ID=2830
NEXON_BOARD_TARGETS=update:2830,notice:2829
NEXON_PAGE_SIZE=100
USER_AGENT=Mozilla/5.0 (compatible; PrasiaPatchBot/0.1; +local)
REQUEST_DELAY=2.0

# Database
DATABASE_PATH=./data/prasia_patchnotes.db
DATABASE_URL=sqlite:./data/prasia_patchnotes.db

# Ingestion
MAX_RETRIES=3

# Vector / Embeddings
VECTOR_BACKEND=local
VECTOR_INDEX_PATH=./data/vector_index.json
EMBEDDING_MODEL=local-tfidf
EMBEDDING_DIMENSIONS=0

# Query
TOP_K=8
HYBRID_CANDIDATES=30
RERANK_ENABLE=true

# Scheduling
SCHEDULE_ENABLED=true
SCHEDULE_CRON=0 9 * * 3

# Policy
DEFAULT_PREFER_LATEST=true
PRESERVE_HISTORY_TOPICS=event,class,world_open,balance

# Optional LLM answer generation
OPENAI_API_KEY=
ANSWER_MODEL=gpt-4.1-mini
